generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth ────────────────────────────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String?
  role            Role      @default(SUBSCRIBER)
  emailVerified   Boolean   @default(false)
  verifyToken     String?   @unique
  verifyTokenExp  DateTime?
  resetToken      String?   @unique
  resetTokenExp   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  sessions        Session[]
  subscription    Subscription?
  postLikes       PostLike[]
  postViews       PostView[]
  aiSearchLogs    AiSearchLog[]
  feedback        Feedback[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  ADMIN
  SUBSCRIBER
  READER
}

// ─── Subscriptions ───────────────────────────────────────────────────────────

model Subscription {
  id                   String              @id @default(cuid())
  userId               String              @unique
  stripeCustomerId     String?             @unique
  stripeSubscriptionId String?             @unique
  status               SubscriptionStatus  @default(FREE)
  plan                 SubscriptionPlan?
  currentPeriodEnd     DateTime?
  trialEnd             DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  user                 User                @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum SubscriptionStatus {
  FREE
  ACTIVE
  PAST_DUE
  CANCELED
}

enum SubscriptionPlan {
  SEEDLING    // $4.99 — all premium posts, unlimited reading
  DEEP_ROOTS  // $9.99 — everything + book discount + exclusive posts
}

// ─── Content ─────────────────────────────────────────────────────────────────

model Post {
  id          String     @id @default(cuid())
  slug        String     @unique
  title       String
  description String
  content     String     // MDX content
  niche       NicheSlug
  isPremium      Boolean    @default(false)
  isDeepRoots    Boolean    @default(false)  // exclusive Deep Roots content
  featuredImage  String?                     // blog featured image URL
  references     String?                     // sources / citations (markdown)
  status         PostStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  affiliateLinks AffiliateLink[]
  postLikes      PostLike[]
  postViews      PostView[]
}

enum NicheSlug {
  faith
  finance
  psychology
  philosophy
  science
}

enum PostStatus {
  DRAFT       // agent-written, awaiting approval
  APPROVED    // approved, scheduled or ready to publish
  PUBLISHED   // live on site
  REJECTED    // denied in CMS
  ARCHIVED
}

// ─── Engagement ──────────────────────────────────────────────────────────────

model PostLike {
  id      String   @id @default(cuid())
  userId  String
  postId  String
  likedAt DateTime @default(now())
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post    Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  @@unique([userId, postId])
}

model PostView {
  id       String   @id @default(cuid())
  userId   String
  postId   String
  viewedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post     Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  @@unique([userId, postId])
}

// ─── Agent Pipeline ──────────────────────────────────────────────────────────

model AgentDraft {
  id          String      @id @default(cuid())
  title       String
  description String
  content     String      // MDX content
  niche       NicheSlug
  isPremium     Boolean     @default(false)
  isDeepRoots   Boolean     @default(false)  // exclusive Deep Roots content
  featuredImage String?                      // blog featured image URL
  references    String?                      // sources / citations (markdown)
  agentName     String      // which agent wrote it (e.g. "Claude Code")
  notes         String?     // agent notes
  createdAt   DateTime    @default(now())
  reviewedAt  DateTime?
  reviewedBy  String?     // admin user id
  status      DraftStatus @default(PENDING)
}

enum DraftStatus {
  PENDING    // in queue, not yet reviewed
  APPROVED   // moved to Post table as APPROVED
  REJECTED
  EDITED     // approved with modifications
}

// ─── User Feedback ───────────────────────────────────────────────────────────

model Feedback {
  id          String          @id @default(cuid())
  userId      String?         // null if submitted while logged out (rare)
  email       String?         // captured at submission for context
  message     String          // raw user message
  type        FeedbackType    @default(COMMENT)
  status      FeedbackStatus  @default(NEW)
  // AI-generated triage data — populated on-demand when admin opens the feedback page
  aiSummary   String?         // one-sentence summary
  aiPriority  FeedbackPriority?
  aiTags      String?         // comma-separated tags like "bug,blocking,paywall"
  aiTriagedAt DateTime?
  // User context
  userAgent   String?
  pageUrl     String?         // where they were when they submitted
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  user        User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
}

enum FeedbackType {
  BUG
  FEATURE
  COMMENT
  QUESTION
}

enum FeedbackStatus {
  NEW
  TRIAGED
  IN_PROGRESS
  RESOLVED
  DISMISSED
}

enum FeedbackPriority {
  CRITICAL  // bug blocking users, payment issues
  HIGH      // requested by many, important fix
  MEDIUM    // useful improvement
  LOW       // nice-to-have, minor
}

// ─── Trial Abuse Prevention ──────────────────────────────────────────────────
// Records emails that have already used a free trial. Survives account
// deletion so users cannot delete + re-signup to get unlimited trials.
model TrialClaim {
  id         String   @id @default(cuid())
  email      String   @unique
  claimedAt  DateTime @default(now())
}

// ─── AI Usage Logging ────────────────────────────────────────────────────────

model AiSearchLog {
  id           String   @id @default(cuid())
  userId       String
  inputTokens  Int
  outputTokens Int
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Affiliate Links ─────────────────────────────────────────────────────────

model AffiliateLink {
  id        String   @id @default(cuid())
  postId    String
  label     String   // display text
  url       String
  provider  String   // "amazon", "other"
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
}
